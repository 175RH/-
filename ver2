<!doctype html>
<html lang="ko">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>시간표</title>
  <style>
    body { font-family: system-ui, sans-serif; margin: 16px; }
    .row { display:flex; gap:8px; flex-wrap:wrap; align-items:center; }
    select, button { padding: 8px 10px; }
    table { border-collapse: collapse; width: 100%; margin-top: 12px; }
    th, td { border: 1px solid #ddd; padding: 8px; text-align: center; vertical-align: top; }
    th { background: #f6f6f6; }
    .muted { color:#666; font-size:13px; margin-top:8px; }

    @media print {
      .no-print { display:none !important; }
      body { margin:0; }
      @page { size: A4 portrait; margin: 10mm; }
      table { font-size: 12px; }
    }
  </style>
</head>
<body>
  <div class="row no-print">
    <button id="modeClass">학급용</button>
    <button id="modeTeacher">교사용</button>
    <button onclick="window.print()">인쇄</button>
  </div>

  <div class="row no-print" style="margin-top:10px">
    <label id="pickLabel">학급 선택</label>
    <select id="picker"></select>
    <button id="reload">새로고침</button>
  </div>

  <div id="title" style="margin-top:14px; font-weight:700; font-size:18px"></div>
  <div class="muted" id="meta"></div>
  <div id="tableWrap"></div>

<script>
  // ✅ Tr의 Apps Script 웹앱 /exec 주소 그대로 유지
  const API_BASE = "https://script.google.com/macros/s/AKfycbxue8gkY89M_4N2DTWVwYH0M1oqcjUPgNlAOinUL1gEz6VMtrQT8Iq188zYUtggLpHzjg/exec";

  const days = ["Mon","Tue","Wed","Thu","Fri"];
  const dayLabel = { Mon:"월", Tue:"화", Wed:"수", Thu:"목", Fri:"금" };
  const periods = [1,2,3,4,5,6,7];

  let mode = "class";

  const picker = document.getElementById("picker");
  const titleEl = document.getElementById("title");
  const metaEl = document.getElementById("meta");
  const tableWrap = document.getElementById("tableWrap");
  const pickLabel = document.getElementById("pickLabel");

  document.getElementById("modeClass").onclick = () => setMode("class");
  document.getElementById("modeTeacher").onclick = () => setMode("teacher");
  document.getElementById("reload").onclick = () => load();

  // ✅ 호출 실패 시 화면에 이유 표시
  async function api(qs) {
    try {
      const url = `${API_BASE}${qs}`;
      const res = await fetch(url);
      const text = await res.text();
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      // JSON이 아닌 HTML(로그인/권한)로 오면 바로 감지
      if (text.trim().startsWith("<")) throw new Error("API 응답이 HTML입니다 권한 또는 API_BASE 확인 필요");
      return JSON.parse(text);
    } catch (err) {
      metaEl.textContent = `불러오기 실패: ${err}`;
      throw err;
    }
  }

  function setMode(m) {
    mode = m;
    pickLabel.textContent = (mode === "class") ? "학급 선택" : "교사 선택";
    load();
  }

  async function load() {
    tableWrap.innerHTML = "";
    titleEl.textContent = "";
    metaEl.textContent = "불러오는 중";

    const list = (mode === "class")
      ? await api("?view=classes")
      : await api("?view=teachers");

    const items = (mode === "class") ? (list.classes || []) : (list.teachers || []);
    if (!items.length) {
      metaEl.textContent = "목록이 비어있음 시트 데이터 또는 API 확인 필요";
      return;
    }

    picker.innerHTML = items.map(v => `<option value="${esc(v)}">${esc(v)}</option>`).join("");
    const chosen = picker.value || items[0];
    await loadTable(chosen);
  }

  picker.onchange = () => loadTable(picker.value);

  function getTodayKey() {
    const map = ["Sun","Mon","Tue","Wed","Thu","Fri","Sat"];
    return map[new Date().getDay()];
  }

  async function loadTable(name) {
    tableWrap.innerHTML = "";
    titleEl.textContent = (mode === "class") ? `학급 시간표 ${name}` : `교사 시간표 ${name}`;
    metaEl.textContent = "불러오는 중";

    const res = await api(`?view=${mode}&name=${encodeURIComponent(name)}`);
    const records = res.data || [];

    // ✅ 분반(동일 요일/교시 칸에 여러 건) 누적 저장
    const map = new Map();
    for (const r of records) {
      const key = `${r.day}_${r.period}`;

      const cell = (mode === "class")
        ? `${r.subject}\n${r.teacher}`
        : `${r.subject}\n${r.class}`;

      if (!map.has(key)) map.set(key, []);
      map.get(key).push(cell);
    }

    const today = getTodayKey();

    let html = "<table><thead><tr><th>교시</th>";
    for (const d of days) {
      const style = (d === today) ? ' style="background:#ffeeba"' : '';
      html += `<th${style}>${dayLabel[d]}</th>`;
    }
    html += "</tr></thead><tbody>";

    for (const p of periods) {
      html += `<tr><th>${p}</th>`;
      for (const d of days) {
        const arr = map.get(`${d}_${p}`) || [];

        // ✅ 분반 배지 표시
        const badge = (arr.length >= 2)
          ? `<div style="font-size:12px;font-weight:700;margin-bottom:6px">분반(${arr.length})</div>`
          : "";

        const cellHtml = badge + arr
          .map(s => esc(s).replaceAll("\n","<br>"))
          .join("<hr style='border:0;border-top:1px solid #ddd;margin:6px 0'>");

        html += `<td>${cellHtml}</td>`;
      }
      html += "</tr>";
    }

    html += "</tbody></table>";
    tableWrap.innerHTML = html;

    metaEl.textContent = `총 ${records.length}개 수업 반영 | 마지막 갱신 ${new Date().toLocaleString()}`;
  }

  function esc(s) {
    return String(s ?? "")
      .replaceAll("&","&amp;")
      .replaceAll("<","&lt;")
      .replaceAll(">","&gt;")
      .replaceAll('"',"&quot;")
      .replaceAll("'","&#039;");
  }

  setMode("class");

  // ✅ 30초마다 자동 갱신
  setInterval(() => loadTable(picker.value), 30000);
</script>
</body>
</html>
